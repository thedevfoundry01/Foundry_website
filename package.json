{
  "name": "flask-blog",
  "version": "1.0.0",
  "description": "A blogging platform built with Flask and modern front-end tools.",
  "main": "postcss.config.js",
  "directories": {
    "test": "tests"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.0.3",
    "@tailwindcss/vite": "^4.0.3"
  },
  "scripts": {
    "dev": "vite",                 
    "build": "vite build",         
    "preview": "vite preview",     
    "watch": "vite --watch",       
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx", 
    "format": "prettier --write .",
    "clean": "rm -rf dist node_modules",
    "postinstall": "vite build"    
  },
  "author": "Kritim Yantra",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.11",
    "eslint": "^8.56.0",          
    "prettier": "^3.2.4"          
  }
}
